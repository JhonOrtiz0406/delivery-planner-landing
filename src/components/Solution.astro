---
const features = [
  {
    title: 'Registro centralizado de pedidos',
    body: 'Un solo lugar para todos tus pedidos, con estado, cliente asignado, responsable de entrega y fecha límite. Sin hojas de cálculo, sin mensajes perdidos.',
    screenshot: 'add-order',
    screenshotLabel: 'Vista de registro de pedidos',
    badge: null,
  },
  {
    title: 'Notificaciones automáticas al cliente',
    body: 'Tus clientes reciben actualizaciones automáticas cuando su pedido avanza. Menos llamadas entrantes, menos interrupciones, clientes más tranquilos.',
    screenshot: 'filter',
    screenshotLabel: 'Vista de notificaciones y filtros',
    badge: 'Próximamente WhatsApp',
  },
  {
    title: 'Roles diferenciados por tipo de usuario',
    body: 'El administrador tiene visibilidad y control total. Los empleados ven solo sus tareas asignadas. Cada quien tiene exactamente lo que necesita.',
    screenshot: 'employees',
    screenshotLabel: 'Vista de gestión de empleados',
    badge: null,
  },
];
---

<section
  class="py-16 md:py-24 bg-white"
  aria-labelledby="solution-heading"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Encabezado -->
    <div class="text-center mb-16">
      <h2
        id="solution-heading"
        class="text-3xl md:text-4xl font-bold text-neutral-900 mb-4"
      >
        Todo lo que necesitas para gestionar tus entregas
      </h2>
      <p class="text-lg text-neutral-600 max-w-2xl mx-auto">
        Sin complicaciones. Sin entrenamiento de días. Tu equipo lo entiende el
        mismo día que lo usa.
      </p>
    </div>

    <!-- Features -->
    <div class="space-y-16 md:space-y-24">
      {features.map((feature, i) => (
        <div
          class={`grid md:grid-cols-2 gap-10 md:gap-16 items-center ${
            i % 2 === 1 ? 'md:flex md:flex-row-reverse' : ''
          }`}
        >
          <!-- Texto -->
          <div>
            {feature.badge && (
              <span class="inline-flex items-center gap-1 bg-accent/10 text-accent-dark text-xs font-semibold px-2.5 py-1 rounded-full mb-4">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 16 16"
                  fill="currentColor"
                  class="w-3.5 h-3.5"
                  aria-hidden="true"
                >
                  <path d="M8 9.5a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3Z" />
                  <path
                    fill-rule="evenodd"
                    d="M1.38 8.28a.87.87 0 0 1 0-.566 7.003 7.003 0 0 1 13.238.006.87.87 0 0 1 0 .566A7.003 7.003 0 0 1 1.379 8.28ZM11 8a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"
                    clip-rule="evenodd"
                  />
                </svg>
                {feature.badge}
              </span>
            )}

            <h3 class="text-2xl md:text-3xl font-bold text-neutral-900 mb-4">
              {feature.title}
            </h3>

            <p class="text-lg text-neutral-600 leading-relaxed mb-6">
              {feature.body}
            </p>

            <!-- Check list -->
            <ul class="space-y-2.5" role="list">
              {[
                i === 0 && ['Asigna responsable por pedido', 'Estados actualizables en tiempo real', 'Historial completo de cada pedido'],
                i === 1 && ['El cliente sabe sin tener que preguntar', 'Reduce llamadas y mensajes repetitivos', 'TODO_VERIFICAR: Canales disponibles de notificación'],
                i === 2 && ['Administrador con vista global', 'Empleado ve solo sus entregas del día', 'Sin accesos innecesarios a datos sensibles'],
              ].flat().filter(Boolean).map((item) => (
                <li class="flex items-start gap-2.5 text-neutral-700">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    class="w-5 h-5 text-accent shrink-0 mt-0.5"
                    aria-hidden="true"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm3.857-9.809a.75.75 0 0 0-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 1 0-1.06 1.061l2.5 2.5a.75.75 0 0 0 1.137-.089l4-5.5Z"
                      clip-rule="evenodd"
                    />
                  </svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Screenshot placeholder -->
          <div
            class="bg-white rounded-2xl border border-neutral-200 shadow-lg overflow-hidden"
            role="img"
            aria-label={`${feature.screenshotLabel} (screenshot pendiente)`}
          >
            <!--
              TODO: Reemplazar por:
              <img
                src={`/screenshots/${feature.screenshot}.png`}
                alt={feature.screenshotLabel}
                class="w-full"
                loading="lazy"
              />
              Archivo esperado: public/screenshots/{feature.screenshot}.png
            -->
            <div class="aspect-video bg-gradient-to-br from-primary-light/60 to-surface flex flex-col items-center justify-center gap-3">
              <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                  stroke="currentColor"
                  class="w-6 h-6 text-primary"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25H12"
                  />
                </svg>
              </div>
              <p class="text-sm font-semibold text-neutral-500">
                {feature.screenshotLabel}
              </p>
              <p class="text-xs text-neutral-400">
                [ Reemplazar con screenshot: {feature.screenshot}.png ]
              </p>
            </div>
          </div>

        </div>
      ))}
    </div>

  </div>
</section>
