---
/**
 * Lightbox reutilizable y data-driven.
 * Recibe un array de imágenes como prop — nada hardcodeado dentro.
 *
 * Uso:
 *   <Lightbox images={gallery} id="hero-gallery" />
 *
 * Para abrirlo, cualquier elemento de la página puede actuar como disparador:
 *   <button data-lightbox-target="hero-gallery" data-lightbox-trigger="0">...</button>
 *   (el número = índice dentro del array de imágenes)
 */
interface ImageItem {
  src: string;
  alt: string;
}

interface Props {
  images: ImageItem[];
  id?: string;
}

const { images, id = 'lightbox' } = Astro.props;
---

<div
  id={id}
  class="lightbox fixed inset-0 z-[60] hidden items-center justify-center bg-black/80 backdrop-blur-sm p-4 sm:p-8"
  role="dialog"
  aria-modal="true"
  aria-label="Galería de capturas del producto"
  data-lightbox-root
>
  <!-- Cerrar -->
  <button
    type="button"
    class="lightbox-close absolute top-4 right-4 w-11 h-11 flex items-center justify-center rounded-full bg-white/10 hover:bg-white/20 text-white transition-colors"
    aria-label="Cerrar galería"
  >
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="w-6 h-6" aria-hidden="true">
      <path d="M6 6l12 12M18 6L6 18" />
    </svg>
  </button>

  <!-- Anterior -->
  <button
    type="button"
    class="lightbox-prev absolute left-2 sm:left-4 top-1/2 -translate-y-1/2 w-11 h-11 flex items-center justify-center rounded-full bg-white/10 hover:bg-white/20 text-white transition-colors"
    aria-label="Imagen anterior"
  >
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6" aria-hidden="true">
      <path d="M15 18l-6-6 6-6" />
    </svg>
  </button>

  <!-- Siguiente -->
  <button
    type="button"
    class="lightbox-next absolute right-2 sm:right-4 top-1/2 -translate-y-1/2 w-11 h-11 flex items-center justify-center rounded-full bg-white/10 hover:bg-white/20 text-white transition-colors"
    aria-label="Imagen siguiente"
  >
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6" aria-hidden="true">
      <path d="M9 6l6 6-6 6" />
    </svg>
  </button>

  <!-- Imagen -->
  <figure class="flex flex-col items-center gap-3 max-w-full">
    <img
      class="lightbox-img max-h-[80vh] max-w-[92vw] w-auto h-auto rounded-lg shadow-2xl object-contain"
      src=""
      alt=""
      loading="lazy"
    />
    <figcaption class="lightbox-caption text-white/80 text-sm text-center max-w-xl"></figcaption>
  </figure>

  <!-- Contador -->
  <div class="lightbox-counter absolute bottom-4 left-1/2 -translate-x-1/2 text-white/70 text-sm tabular-nums" aria-live="polite"></div>
</div>

<script define:vars={{ images, id }}>
  function initLightbox() {
    const root = document.getElementById(id);
    if (!root || images.length === 0) return;

    const imgEl = root.querySelector('.lightbox-img');
    const captionEl = root.querySelector('.lightbox-caption');
    const counterEl = root.querySelector('.lightbox-counter');
    const btnClose = root.querySelector('.lightbox-close');
    const btnPrev = root.querySelector('.lightbox-prev');
    const btnNext = root.querySelector('.lightbox-next');

    let current = 0;
    let lastFocused = null;

    function render() {
      const item = images[current];
      imgEl.src = item.src;
      imgEl.alt = item.alt;
      captionEl.textContent = item.alt;
      counterEl.textContent = `${current + 1} / ${images.length}`;
    }

    function open(index) {
      current = (index + images.length) % images.length;
      render();
      lastFocused = document.activeElement;
      root.classList.remove('hidden');
      root.classList.add('flex');
      document.body.style.overflow = 'hidden';
      btnClose.focus();
      document.addEventListener('keydown', onKey);
    }

    function close() {
      root.classList.add('hidden');
      root.classList.remove('flex');
      document.body.style.overflow = '';
      document.removeEventListener('keydown', onKey);
      if (lastFocused && typeof lastFocused.focus === 'function') lastFocused.focus();
    }

    const next = () => { current = (current + 1) % images.length; render(); };
    const prev = () => { current = (current - 1 + images.length) % images.length; render(); };

    function onKey(e) {
      if (e.key === 'Escape') { close(); return; }
      if (e.key === 'ArrowRight') { next(); return; }
      if (e.key === 'ArrowLeft') { prev(); return; }
      if (e.key === 'Tab') {
        // Focus trap: ciclar solo entre los botones del modal
        const focusables = [btnClose, btnPrev, btnNext];
        const first = focusables[0];
        const last = focusables[focusables.length - 1];
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }
    }

    btnClose.addEventListener('click', close);
    btnNext.addEventListener('click', next);
    btnPrev.addEventListener('click', prev);
    // Clic en el fondo (no en la figura) cierra
    root.addEventListener('click', (e) => { if (e.target === root) close(); });

    // Swipe táctil (mobile)
    let startX = 0;
    root.addEventListener('touchstart', (e) => { startX = e.changedTouches[0].clientX; }, { passive: true });
    root.addEventListener('touchend', (e) => {
      const dx = e.changedTouches[0].clientX - startX;
      if (Math.abs(dx) > 50) { dx < 0 ? next() : prev(); }
    }, { passive: true });

    // Conectar disparadores de esta galería
    document.querySelectorAll(`[data-lightbox-target="${id}"]`).forEach((el) => {
      el.addEventListener('click', () => {
        const idx = parseInt(el.getAttribute('data-lightbox-trigger') || '0', 10);
        open(idx);
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initLightbox);
  } else {
    initLightbox();
  }
</script>
