---
import { WHATSAPP_URL } from '../lib/config';

const plans = [
  {
    name: 'Mensual',
    price: '$140.000',
    period: '/mes',
    setup: '$800.000',
    freeSetup: false,
    description: 'Ideal para empezar y evaluar el producto sin compromisos largos.',
    recommended: false,
    features: [
      'Registro ilimitado de pedidos y entregas',
      'Hasta 5 usuarios (administrador + empleados)',
      'Acceso desde cualquier dispositivo, sin instalar nada',
      'Notificaciones automáticas a tus clientes',
      'Soporte por WhatsApp',
      'Setup y configuración inicial incluidos',
    ],
    cta: 'Empezar mensual',
  },
  {
    name: 'Anual',
    price: '$1.680.000',
    period: '/año',
    setup: '$800.000',
    freeSetup: true,
    description: 'Compromiso anual con el mismo costo mensual. Acceso garantizado todo el año.',
    recommended: true,
    features: [
      'Todo lo del plan Mensual',
      'Usuarios ilimitados — suma a todo tu equipo sin costo extra',
      'Pago único anual: olvídate del cobro mes a mes',
      'Precio congelado los 12 meses, sin sorpresas',
      'Soporte prioritario por WhatsApp',
      'Nuevas funciones incluidas sin costo adicional',
    ],
    cta: 'Empezar anual',
  },
];
---

<section
  class="py-16 md:py-24 bg-white"
  aria-labelledby="pricing-heading"
  id="precios"
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Encabezado -->
    <div class="text-center mb-12">
      <h2
        id="pricing-heading"
        class="text-3xl md:text-4xl font-bold text-neutral-900 mb-4"
      >
        Planes y precios
      </h2>
      <p class="text-lg text-neutral-600 max-w-xl mx-auto">
        Precios en pesos colombianos. Sin costos ocultos. Sin sorpresas.
      </p>

      <!-- Refuerzo: el ahorro empuja hacia el plan anual -->
      <p class="inline-flex items-center gap-2 mt-5 bg-accent-light text-accent-dark font-semibold text-sm px-4 py-2 rounded-full">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="currentColor"
          class="w-4 h-4 shrink-0"
          aria-hidden="true"
        >
          <path d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z" />
        </svg>
        Setup gratis solo en plan anual — ahorras $800.000
      </p>
    </div>

    <!-- Cards de planes -->
    <div class="grid md:grid-cols-2 gap-6 items-start">
      {plans.map((plan) => (
        <div
          class={`rounded-2xl border-2 p-8 flex flex-col gap-6 relative ${
            plan.recommended
              ? 'border-primary shadow-xl shadow-primary/10'
              : 'border-neutral-200 shadow-sm'
          }`}
          aria-label={`Plan ${plan.name}${plan.recommended ? ' — Recomendado' : ''}`}
        >

          <!-- Badge recomendado -->
          {plan.recommended && (
            <div
              class="absolute -top-3.5 left-1/2 -translate-x-1/2"
              aria-label="Plan recomendado"
            >
              <span class="bg-primary text-white text-xs font-bold px-4 py-1.5 rounded-full shadow-sm">
                Recomendado
              </span>
            </div>
          )}

          <!-- Nombre y descripción -->
          <div>
            <h3 class="text-xl font-bold text-neutral-900 mb-1">{plan.name}</h3>
            <p class="text-sm text-neutral-500">{plan.description}</p>
          </div>

          <!-- Precio -->
          <div>
            <div class="flex items-end gap-1">
              <span class="text-4xl font-bold text-neutral-900">{plan.price}</span>
              <span class="text-neutral-500 mb-1.5 text-base">{plan.period}</span>
            </div>
            {plan.freeSetup ? (
              <p class="text-sm font-semibold text-accent-dark mt-2 inline-flex items-center gap-1.5">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  class="w-4 h-4 shrink-0"
                  aria-hidden="true"
                >
                  <path d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z" />
                </svg>
                Setup y configuración GRATIS — ahorras {plan.setup}
              </p>
            ) : (
              <p class="text-sm text-neutral-500 mt-1.5">
                + Setup único{' '}
                <span class="font-semibold text-neutral-700">{plan.setup}</span>
                {' '}(una sola vez)
              </p>
            )}
          </div>

          <!-- Separador -->
          <hr class="border-neutral-200" />

          <!-- Features -->
          <ul class="space-y-3 flex-1" role="list">
            {plan.features.map((feature) => (
              <li class="flex items-start gap-2.5 text-sm text-neutral-700">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                  class="w-5 h-5 text-accent shrink-0 mt-0.5"
                  aria-hidden="true"
                >
                  <path
                    fill-rule="evenodd"
                    d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm3.857-9.809a.75.75 0 0 0-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 1 0-1.06 1.061l2.5 2.5a.75.75 0 0 0 1.137-.089l4-5.5Z"
                    clip-rule="evenodd"
                  />
                </svg>
                <span class={feature.startsWith('TODO_') ? 'text-neutral-400 italic' : ''}>
                  {feature}
                </span>
              </li>
            ))}
          </ul>

          <!-- CTA -->
          <a
            href={WHATSAPP_URL}
            target="_blank"
            rel="noopener noreferrer"
            class={`inline-flex items-center justify-center gap-2 w-full py-3.5 rounded-xl font-semibold text-base transition-colors duration-200 min-h-[52px] ${
              plan.recommended
                ? 'bg-primary hover:bg-primary-dark text-white'
                : 'border-2 border-primary text-primary hover:bg-primary-light'
            }`}
            aria-label={`${plan.cta} — Contactar por WhatsApp`}
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="w-5 h-5 shrink-0"
              aria-hidden="true"
            >
              <path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"
              ></path>
            </svg>
            {plan.cta}
          </a>

        </div>
      ))}
    </div>

    <!-- Nota de pie -->
    <p class="text-center text-sm text-neutral-400 mt-8">
      ¿Tienes preguntas sobre precios o necesidades especiales?{' '}
      <a
        href={WHATSAPP_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="text-primary hover:underline font-medium"
      >
        Escríbenos por WhatsApp
      </a>{' '}
      y te respondemos hoy.
    </p>

  </div>
</section>
