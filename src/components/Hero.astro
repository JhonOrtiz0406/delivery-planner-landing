---
import { WHATSAPP_URL, DEMO_URL } from '../lib/config';
import Lightbox from './Lightbox.astro';

// Fuente única de la galería del hero. El índice 0 es la imagen principal;
// el resto son las miniaturas. Tanto el hero como el Lightbox la consumen.
const gallery = [
  { src: '/dashboard.png', alt: 'Dashboard principal de Delivery Planner — vista de pedidos y calendario', label: 'Gestión' },
  { src: '/pedidos.png', alt: 'Vista de registro de pedidos en Delivery Planner', label: 'Pedidos' },
  { src: '/equipo.png', alt: 'Vista de gestión de equipo en Delivery Planner', label: 'Equipo' },
  { src: '/invitacionOrganizacionGmail.png', alt: 'Invitación de cliente a la organización por Gmail', label: 'Invitar' },
];
---

<section
  class="bg-gradient-to-b from-primary-light/40 to-white py-16 md:py-24 overflow-hidden"
  aria-labelledby="hero-heading"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid md:grid-cols-2 gap-12 items-center">

      <!-- Columna izquierda: texto -->
      <div class="order-1">

        <!-- Badge -->
        <div
          class="inline-flex items-center gap-1.5 bg-accent/10 text-accent-dark text-sm font-medium px-3 py-1 rounded-full mb-6"
          aria-hidden="true"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 20 20"
            fill="currentColor"
            class="w-4 h-4"
            aria-hidden="true"
          >
            <path
              fill-rule="evenodd"
              d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z"
              clip-rule="evenodd"
            />
          </svg>
          Usado por negocios en Colombia
        </div>

        <!-- Titular -->
        <h1
          id="hero-heading"
          class="text-4xl md:text-5xl font-bold text-neutral-900 leading-tight mb-5"
        >
          Gestiona las entregas de tu negocio sin perderle el rastro a un solo
          pedido
        </h1>

        <!-- Subtítulo -->
        <p class="text-lg text-neutral-600 mb-8 leading-relaxed">
          Delivery Planner centraliza tus pedidos, organiza a tu equipo y
          mantiene a tus clientes informados — todo desde el celular, sin
          instalar nada.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-3">
          <a
            href={WHATSAPP_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-dark text-white px-6 py-3.5 rounded-lg font-semibold transition-colors duration-200 text-base min-h-[52px]"
            aria-label="Contactar ventas por WhatsApp"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="w-5 h-5 shrink-0"
              aria-hidden="true"
            >
              <path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"
              ></path>
            </svg>
            Hablar por WhatsApp
          </a>

          <a
            href={DEMO_URL}
            class="inline-flex items-center justify-center gap-2 border-2 border-primary text-primary hover:bg-primary-light px-6 py-3.5 rounded-lg font-semibold transition-colors duration-200 text-base min-h-[52px]"
            aria-label="Ver demostración del producto"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="w-5 h-5 shrink-0"
              aria-hidden="true"
            >
              <circle cx="12" cy="12" r="10" />
              <polygon points="10 8 16 12 10 16 10 8" fill="currentColor" stroke="none" />
            </svg>
            Ver demo
          </a>
        </div>

        <!-- Social proof -->
        <div
          class="flex items-center gap-2 mt-8 text-sm text-neutral-500"
          aria-label="Prueba social"
        >
          <div class="flex" aria-hidden="true">
            {[1, 2, 3, 4, 5].map(() => (
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 20 20"
                fill="currentColor"
                class="w-4 h-4 text-yellow-400"
              >
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <span>1 cliente activo · Joyería KoB, El Bordo, Cauca</span>
        </div>
      </div>

      <!-- Columna derecha: mockup del producto -->
      <div class="order-2">
        <div class="relative">

          <!-- Marco browser del producto -->
          <div
            class="bg-white rounded-2xl shadow-2xl border border-neutral-200 overflow-hidden"
            aria-label="Vista previa del producto Delivery Planner"
            role="img"
          >
            <!-- Chrome del browser -->
            <div class="bg-neutral-50 px-4 py-2.5 flex items-center gap-3 border-b border-neutral-200">
              <div class="flex gap-1.5" aria-hidden="true">
                <div class="w-3 h-3 rounded-full bg-red-400"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
                <div class="w-3 h-3 rounded-full bg-green-400"></div>
              </div>
              <div
                class="flex-1 bg-white rounded-md px-3 py-1 text-xs text-neutral-400 text-center truncate border border-neutral-200"
                aria-hidden="true"
              >
                app.delivery-planner.bystepsolutions.tech
              </div>
            </div>

            <!-- Barra de navegación interna del app -->
            <div class="bg-primary px-4 py-2 flex gap-1 overflow-x-auto" aria-hidden="true">
              {['Pedidos', 'Calendario', 'Empleados', 'Reportes'].map((tab, i) => (
                <span
                  class={`text-xs px-3 py-1 rounded font-medium whitespace-nowrap ${
                    i === 1
                      ? 'bg-white/20 text-white'
                      : 'text-white/70'
                  }`}
                >
                  {tab}
                </span>
              ))}
            </div>

            <button
              type="button"
              class="group relative block w-full cursor-zoom-in"
              data-lightbox-target="hero-gallery"
              data-lightbox-trigger="0"
              aria-label="Ampliar: dashboard principal de Delivery Planner"
            >
              <img
                src={gallery[0].src}
                alt={gallery[0].alt}
                width="800"
                height="450"
                class="w-full transition-transform duration-300 group-hover:scale-[1.02]"
                loading="eager"
              />
              <!-- Affordance: lupa al hover -->
              <span
                class="absolute inset-0 flex items-center justify-center bg-black/0 group-hover:bg-black/20 transition-colors duration-200"
                aria-hidden="true"
              >
                <span class="opacity-0 group-hover:opacity-100 transition-opacity duration-200 bg-white/90 rounded-full p-2.5 shadow-lg">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-neutral-900">
                    <circle cx="11" cy="11" r="7" />
                    <path d="M21 21l-4.3-4.3M11 8v6M8 11h6" />
                  </svg>
                </span>
              </span>
            </button>
          </div>

          <!-- Thumbnails de las otras vistas (clic = abrir en grande) -->
          <div class="grid grid-cols-4 gap-2 mt-3" aria-label="Otras vistas del producto — clic para ampliar">
            {gallery.map((thumb, i) => (
              <button
                type="button"
                class="group relative bg-white rounded-xl border border-neutral-200 shadow-sm overflow-hidden cursor-zoom-in"
                data-lightbox-target="hero-gallery"
                data-lightbox-trigger={i}
                aria-label={`Ampliar: ${thumb.alt}`}
              >
                <img
                  src={thumb.src}
                  alt={`Vista ${thumb.label} en Delivery Planner`}
                  class="w-full aspect-video object-cover transition-transform duration-300 group-hover:scale-110"
                  loading="lazy"
                />
                <span
                  class="absolute inset-0 flex items-center justify-center bg-black/0 group-hover:bg-black/25 transition-colors duration-200"
                  aria-hidden="true"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-white opacity-0 group-hover:opacity-100 transition-opacity duration-200">
                    <circle cx="11" cy="11" r="7" />
                    <path d="M21 21l-4.3-4.3M11 8v6M8 11h6" />
                  </svg>
                </span>
              </button>
            ))}
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Lightbox de la galería del hero -->
  <Lightbox images={gallery} id="hero-gallery" />
</section>
