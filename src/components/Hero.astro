---
import { WHATSAPP_URL, DEMO_URL } from '../lib/config';

const screenshots = [
  { id: 'login',      label: 'Inicio de sesión',   icon: 'lock' },
  { id: 'calendar',   label: 'Calendario',          icon: 'calendar' },
  { id: 'add-order',  label: 'Nuevo pedido',        icon: 'plus-circle' },
  { id: 'employees',  label: 'Empleados',           icon: 'users' },
  { id: 'filter',     label: 'Filtros',             icon: 'filter' },
];
---

<section
  class="bg-gradient-to-b from-primary-light/40 to-white py-16 md:py-24 overflow-hidden"
  aria-labelledby="hero-heading"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid md:grid-cols-2 gap-12 items-center">

      <!-- Columna izquierda: texto -->
      <div class="order-1">

        <!-- Badge -->
        <div
          class="inline-flex items-center gap-1.5 bg-accent/10 text-accent-dark text-sm font-medium px-3 py-1 rounded-full mb-6"
          aria-hidden="true"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 20 20"
            fill="currentColor"
            class="w-4 h-4"
            aria-hidden="true"
          >
            <path
              fill-rule="evenodd"
              d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z"
              clip-rule="evenodd"
            />
          </svg>
          Usado por negocios en Medellín, Colombia
        </div>

        <!-- Titular -->
        <h1
          id="hero-heading"
          class="text-4xl md:text-5xl font-bold text-neutral-900 leading-tight mb-5"
        >
          Gestiona las entregas de tu negocio sin perderle el rastro a un solo
          pedido
        </h1>

        <!-- Subtítulo -->
        <p class="text-lg text-neutral-600 mb-8 leading-relaxed">
          Delivery Planner centraliza tus pedidos, organiza a tu equipo y
          mantiene a tus clientes informados — todo desde el celular, sin
          instalar nada.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-3">
          <a
            href={WHATSAPP_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-dark text-white px-6 py-3.5 rounded-lg font-semibold transition-colors duration-200 text-base min-h-[52px]"
            aria-label="Contactar ventas por WhatsApp"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="w-5 h-5 shrink-0"
              aria-hidden="true"
            >
              <path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"
              ></path>
            </svg>
            Hablar por WhatsApp
          </a>

          <!--
            TODO_VERIFICAR: Definir URL del demo.
            Opciones: video de YouTube, enlace al producto en producción, o página de demo separada.
            Actualizar PUBLIC_DEMO_URL en .env
          -->
          <a
            href={DEMO_URL}
            class="inline-flex items-center justify-center gap-2 border-2 border-primary text-primary hover:bg-primary-light px-6 py-3.5 rounded-lg font-semibold transition-colors duration-200 text-base min-h-[52px]"
            aria-label="Ver demostración del producto"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="w-5 h-5 shrink-0"
              aria-hidden="true"
            >
              <circle cx="12" cy="12" r="10" />
              <polygon points="10 8 16 12 10 16 10 8" fill="currentColor" stroke="none" />
            </svg>
            Ver demo
          </a>
        </div>

        <!-- Social proof -->
        <div
          class="flex items-center gap-2 mt-8 text-sm text-neutral-500"
          aria-label="Prueba social"
        >
          <div class="flex" aria-hidden="true">
            {[1, 2, 3, 4, 5].map(() => (
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 20 20"
                fill="currentColor"
                class="w-4 h-4 text-yellow-400"
              >
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <span>1 cliente activo · Joyería en Medellín</span>
        </div>
      </div>

      <!-- Columna derecha: mockup del producto -->
      <div class="order-2">
        <div class="relative">

          <!-- Marco browser del producto -->
          <div
            class="bg-white rounded-2xl shadow-2xl border border-neutral-200 overflow-hidden"
            aria-label="Vista previa del producto Delivery Planner"
            role="img"
          >
            <!-- Chrome del browser -->
            <div class="bg-neutral-50 px-4 py-2.5 flex items-center gap-3 border-b border-neutral-200">
              <div class="flex gap-1.5" aria-hidden="true">
                <div class="w-3 h-3 rounded-full bg-red-400"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
                <div class="w-3 h-3 rounded-full bg-green-400"></div>
              </div>
              <div
                class="flex-1 bg-white rounded-md px-3 py-1 text-xs text-neutral-400 text-center truncate border border-neutral-200"
                aria-hidden="true"
              >
                delivery-planner.bystepsolutions.tech
              </div>
            </div>

            <!-- Barra de navegación interna del app -->
            <div class="bg-primary px-4 py-2 flex gap-1 overflow-x-auto" aria-hidden="true">
              {['Pedidos', 'Calendario', 'Empleados', 'Reportes'].map((tab, i) => (
                <span
                  class={`text-xs px-3 py-1 rounded font-medium whitespace-nowrap ${
                    i === 1
                      ? 'bg-white/20 text-white'
                      : 'text-white/70'
                  }`}
                >
                  {tab}
                </span>
              ))}
            </div>

            <!--
              SCREENSHOT PRINCIPAL: Vista de Calendario
              TODO: Reemplazar por:
              <img
                src="/screenshots/calendar.png"
                alt="Vista de calendario de pedidos en Delivery Planner"
                width="800"
                height="450"
                class="w-full"
                loading="eager"
              />
              Archivo esperado: public/screenshots/calendar.png
            -->
            <div
              class="aspect-video bg-gradient-to-br from-primary-light to-neutral-50 flex flex-col items-center justify-center gap-3 relative overflow-hidden"
              role="img"
              aria-label="Pantalla principal — Vista de Calendario (screenshot pendiente)"
            >
              <!-- Grid de fondo simulando calendario -->
              <div class="absolute inset-0 grid grid-cols-7 gap-px p-6 opacity-10" aria-hidden="true">
                {Array(35).fill(null).map(() => (
                  <div class="bg-primary rounded-sm"></div>
                ))}
              </div>

              <div class="relative z-10 text-center px-4">
                <div class="w-14 h-14 bg-primary/15 rounded-2xl flex items-center justify-center mx-auto mb-3">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="1.5"
                    stroke="currentColor"
                    class="w-7 h-7 text-primary"
                    aria-hidden="true"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5"
                    />
                  </svg>
                </div>
                <p class="text-sm font-semibold text-neutral-600">Vista de Calendario</p>
                <p class="text-xs text-neutral-400 mt-1">[ Reemplazar con screenshot real ]</p>
              </div>
            </div>
          </div>

          <!-- Thumbnails de las otras vistas -->
          <div class="grid grid-cols-4 gap-2 mt-3" aria-label="Otras vistas del producto">
            {[
              { label: 'Login',    icon: 'lock',     id: 'login'     },
              { label: 'Pedidos',  icon: 'list',     id: 'add-order' },
              { label: 'Equipo',   icon: 'users',    id: 'employees' },
              { label: 'Filtros',  icon: 'filter',   id: 'filter'    },
            ].map((thumb) => (
              <div
                class="bg-white rounded-xl border border-neutral-200 shadow-sm overflow-hidden"
                role="img"
                aria-label={`Vista: ${thumb.label} (screenshot pendiente)`}
              >
                <!--
                  TODO: Reemplazar por:
                  <img src={`/screenshots/${thumb.id}.png`} alt={`Vista ${thumb.label}`} class="w-full" loading="lazy" />
                -->
                <div class="aspect-video bg-neutral-50 flex flex-col items-center justify-center gap-1">
                  <div class="w-6 h-6 bg-primary/10 rounded flex items-center justify-center">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke-width="2"
                      stroke="currentColor"
                      class="w-3.5 h-3.5 text-primary"
                      aria-hidden="true"
                    >
                      <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25H12" />
                    </svg>
                  </div>
                  <span class="text-[10px] text-neutral-400 font-medium leading-none">
                    {thumb.label}
                  </span>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
